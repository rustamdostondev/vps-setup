choose_language() {  # interactive 2-option picker; works before main menu too
  local cur=0 k
  [[ "$UI_LANG" == "uz" ]] && cur=1
  tput civis 2>/dev/null || true
  while true; do
    printf '\033[H\033[2J'
    echo ""
    echo "  ${CB}$(t choose_lang)${C0}"
    echo ""
    if [[ $cur -eq 0 ]]; then
      echo "  ${CBCYN}${G_CUR} English${C0}"
      echo "    O'zbekcha"
    else
      echo "    English"
      echo "  ${CBCYN}${G_CUR} O'zbekcha${C0}"
    fi
    echo ""
    echo "  ${CGRY}[enter] OK${C0}"
    k=$(read_key) || k=""
    case "$k" in
      $'\e[A'|k) cur=0 ;;
      $'\e[B'|j) cur=1 ;;
      "") break ;;
    esac
  done
  if [[ $cur -eq 1 ]]; then UI_LANG="uz"; else UI_LANG="en"; fi
  save_lang "$UI_LANG"
}

cmd_menu() {
  require_root
  require_ubuntu
  if [[ $IS_TTY -eq 0 ]]; then
    echo "$(t err_no_tty)" >&2
    cmd_status
    return 0
  fi

  # first run ‚Üí language choice
  if [[ ! -f "$LANG_FILE" && -z "${VPS_LANG:-}" ]]; then
    enter_alt
    choose_language
    leave_alt
  fi

  detect_ips
  compute_statuses
  local i k
  for i in "${!SERVICES[@]}"; do SEL[$i]=0; done

  enter_alt
  printf '\033[2J'
  while true; do
    draw_menu
    k=$(read_key) || k="q"
    case "$k" in
      $'\e[A'|k) CUR=$(( (CUR + ${#SERVICES[@]} - 1) % ${#SERVICES[@]} )) ;;
      $'\e[B'|j) CUR=$(( (CUR + 1) % ${#SERVICES[@]} )) ;;
      " ")
        if [[ "${SEL[$CUR]}" == "1" ]]; then SEL[$CUR]=0; else SEL[$CUR]=1; fi
        ;;
      a)
        local all=1
        for i in "${!SERVICES[@]}"; do [[ "${SEL[$i]}" == "0" ]] && all=0; done
        for i in "${!SERVICES[@]}"; do
          if [[ $all -eq 1 ]]; then SEL[$i]=0; else SEL[$i]=1; fi
        done
        ;;
      "") menu_install_flow; printf '\033[2J' ;;
      r) compute_statuses ;;
      c) menu_show_creds; printf '\033[2J' ;;
      i) menu_show_info; printf '\033[2J' ;;
      l) choose_language; printf '\033[2J' ;;
      q|$'\e') break ;;
    esac
  done
  leave_alt
}

