cmd_install() {
  require_root
  require_ubuntu
  init_dirs

  [[ $# -eq 0 ]] && { cmd_help; die "$(t err_unknown_svc) (none given)"; }

  local requested=() s
  if [[ "$1" == "all" ]]; then
    requested=("${SERVICES[@]}")
  else
    for s in "$@"; do
      s="$(lower "$s")"
      is_service "$s" || die "$(t err_unknown_svc) $s  (services: ${SERVICES[*]})"
      requested+=("$s")
    done
  fi

  validate_supplied_passwords
  detect_ips
  compute_statuses
  build_queue "${requested[@]}"

  if [[ ${#RUN_QUEUE[@]} -eq 0 ]]; then
    echo "${CGRN}${G_OK} $(t nothing)${C0}"
    return 0
  fi

  print_plan
  local rc=0
  run_queue || rc=1
  echo ""
  compute_statuses
  cmd_status_table
  return $rc
}

cmd_status_table() {
  local s st
  echo ""
  echo "  ${CB}$(t status_title)${C0}  ${CD}$(os_pretty)${C0}"
