#
#   Interactive Ubuntu VPS provisioning CLI.
#   Full backend environment ‚ÄĒ pick services one by one, or all at once.
#
#   Usage:
#     sudo vps                     interactive menu (TUI)
#     sudo vps install all         install everything (non-interactive)
#     sudo vps install postgres    install one service (+ dependencies)
#     sudo vps status              show what is installed
#     sudo vps creds               show generated credentials
#     vps help                     full help
#
#   Guarantees (same as the original vps-setup.sh):
#     - IDEMPOTENT       safe to re-run any number of times
#     - RESUME-SAFE      failed halfway? run again, it continues
#     - NON-DESTRUCTIVE  existing configs are backed up to .bak.* first
#
# =====================================================================
set -Eeuo pipefail

VERSION="1.2.0"

# Absolute path to this script (needed to spawn install steps as fresh
# processes where `set -e` is fully honored, and for self-update)
SELF="${BASH_SOURCE[0]}"
case "$SELF" in /*) ;; *) SELF="$PWD/$SELF" ;; esac
# ---------------------------------------------------------------------
# PUBLISH: replace with your GitHub "username/repo" before publishing.
# Used by `vps update` (self-update) and shown in help.
# ---------------------------------------------------------------------
REPO_SLUG="${VPS_SETUP_REPO:-rustamdostondev/vps-setup}"
RAW_BASE="https://raw.githubusercontent.com/${REPO_SLUG}/main"

# ---------------------------------------------------------------------
# Global paths / mode
# ---------------------------------------------------------------------
DEMO="${VPS_DEMO:-0}"                    # VPS_DEMO=1 ‚Üí mock mode (local dev/preview)
if [[ "$DEMO" == "1" ]]; then
  CONF_DIR="${TMPDIR:-/tmp}/vps-setup-demo"
  LOG_FILE="$CONF_DIR/vps-setup.log"
  CREDS_FILE="$CONF_DIR/server-credentials.txt"
else
  CONF_DIR="/etc/vps-setup"
  LOG_FILE="/var/log/vps-setup.log"
  CREDS_FILE="/root/server-credentials.txt"
fi
LANG_FILE="$CONF_DIR/lang"
DEMO_STATE="$CONF_DIR/demo-installed"
INFRA_DIR="/opt/infra"
BACKUP_DIR="/opt/backups"
CICD_KEY="/root/.ssh/github_cicd"

SERVICES=(system swap nodejs docker postgres valkey minio backup nginx firewall sshkey)

# ---------------------------------------------------------------------
# Terminal capabilities: colors + glyphs (UTF-8 detection, NO_COLOR)
# ---------------------------------------------------------------------
IS_TTY=0; [[ -t 1 && -t 0 ]] && IS_TTY=1

if [[ -n "${NO_COLOR:-}" || "${TERM:-}" == "dumb" || $IS_TTY -eq 0 ]]; then
  C0="" CB="" CD="" CRED="" CGRN="" CBGRN="" CYLW="" CCYN="" CBCYN="" CGRY=""
else
  C0=$'\033[0m'  CB=$'\033[1m'   CD=$'\033[2m'
  CRED=$'\033[1;31m' CGRN=$'\033[0;32m' CBGRN=$'\033[1;32m'
  CYLW=$'\033[1;33m' CCYN=$'\033[0;36m' CBCYN=$'\033[1;36m' CGRY=$'\033[0;90m'
fi

_loc="${LC_ALL:-${LC_CTYPE:-${LANG:-}}}"
if [[ "$_loc" == *[Uu][Tt][Ff]* ]]; then
  G_OK="‚úď" G_PART="‚óź" G_OFF="¬∑" G_CUR="‚ĚĮ" G_ON="‚óČ" G_UN="‚óč" G_ERR="‚úó"
  SPIN_FRAMES="‚†č‚†ô‚†Ļ‚†ł‚†ľ‚†ī‚†¶‚†ß‚†á‚†Ź"
  BTL="‚ē≠" BTR="‚ēģ" BBL="‚ēį" BBR="‚ēĮ" BH="‚ĒÄ" BV="‚Ēā"
else
  G_OK="+" G_PART="~" G_OFF="." G_CUR=">" G_ON="[x]" G_UN="[ ]" G_ERR="x"
  SPIN_FRAMES='|/-\'
  BTL="+" BTR="+" BBL="+" BBR="+" BH="-" BV="|"
fi

