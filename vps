  echo "==> setting up daily Postgres backup"
  mkdir -p "$BACKUP_DIR"
  cat > /etc/cron.daily/pg-backup <<'BACKUP'
#!/usr/bin/env bash
# pipefail: a failed pg_dump must NOT produce a "successful" empty backup
set -euo pipefail
source /opt/infra/.env
BACKUP_DIR=/opt/backups
mkdir -p "$BACKUP_DIR"
out="$BACKUP_DIR/${POSTGRES_DB}_$(date +%F).sql.gz"
tmp=$(mktemp "$BACKUP_DIR/.pg-backup.XXXXXX")
trap 'rm -f "$tmp"' EXIT
docker exec postgres pg_dump -U "$POSTGRES_USER" "$POSTGRES_DB" | gzip > "$tmp"
mv "$tmp" "$out"
# retention runs ONLY after a successful dump ‚ÄĒ a broken postgres can never
# rotate away the last good backups
find "$BACKUP_DIR" -name "*.sql.gz" -mtime +7 -delete
BACKUP
  chmod +x /etc/cron.daily/pg-backup
  ok "daily backup to $BACKUP_DIR, 7 days retained"
}

