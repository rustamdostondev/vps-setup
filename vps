IN_ALT=0
enter_alt() { [[ $IS_TTY -eq 1 ]] || return 0; tput smcup 2>/dev/null || true; tput civis 2>/dev/null || true; IN_ALT=1; }
leave_alt() { [[ $IN_ALT -eq 1 ]] || return 0; tput cnorm 2>/dev/null || true; tput rmcup 2>/dev/null || true; IN_ALT=0; }

cleanup() {
  [[ $IS_TTY -eq 1 ]] && { tput cnorm 2>/dev/null || true; }
  leave_alt
  # only the process that created WARN_FILE removes it (install-step child
  # processes inherit the path and must not delete it under the parent)
  if [[ $OWNS_WARN_FILE -eq 1 && -n "${WARN_FILE:-}" && -f "$WARN_FILE" ]]; then
    rm -f "$WARN_FILE" 2>/dev/null || true
  fi
}
on_int() {
  if [[ -n "$CHILD_PID" ]]; then
    # the step runs in its own process group (setsid) ‚ÄĒ kill the whole
    # group so apt-get/dpkg children die too and release the dpkg lock
    kill -- -"$CHILD_PID" 2>/dev/null || kill "$CHILD_PID" 2>/dev/null || true
  fi
  cleanup
  exit 130
}
trap cleanup EXIT
trap on_int INT TERM

STEP="startup"
on_error() {
  cleanup
  echo -e "\n${CRED}${G_ERR} $(t err_step): \"${STEP}\" (line: $1)${C0}" >&2
  echo -e "${CYLW}$(t rerun)${C0}" >&2
}
trap 'on_error $LINENO' ERR

read_key() {
  local k rest=""
  IFS= read -rsn1 k || return 1
  if [[ "$k" == $'\e' ]]; then
    # arrow keys arrive as ESC [ A/B ‚ÄĒ the extra bytes are already buffered
    IFS= read -rsn2 -t 1 rest 2>/dev/null || true
    k+="$rest"
  fi
  printf '%s' "$k"
}

