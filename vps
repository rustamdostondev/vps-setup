  for s in "${SERVICES[@]}"; do
    st="$(get_status "$s")"
    printf '  %-30s %s\n' "$(t "svc_$s")" "$(status_glyph "$st")"
  done
  echo ""
  echo "  ${CD}${N_OK}/${#SERVICES[@]} $(t ready)${C0}"
  echo ""
}

cmd_status() {
  require_root
  compute_statuses
  cmd_status_table
}

cmd_creds() {
  require_root
  if [[ -f "$CREDS_FILE" ]]; then
    cat "$CREDS_FILE"
    echo ""
    echo "${CYLW}$(t creds_warn)  rm $CREDS_FILE${C0}"
  else
    echo "$(t creds_none)"
  fi
