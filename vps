# =====================================================================
# Small helpers
# =====================================================================
log()  { echo -e "\n${CBGRN}==> $1${C0}"; }
ok()   { echo -e "${CGRN}  ${G_OK} $1${C0}"; }
die()  { echo -e "${CRED}${G_ERR} $1${C0}" >&2; exit 1; }

# WARN_FILE is created by the top-level process and inherited (via env) by
# the __step child processes, so install-time warnings can be replayed on
# screen by the parent. Only the creator removes it.
OWNS_WARN_FILE=0
init_warn_file() {
  if [[ -z "${WARN_FILE:-}" ]]; then
    WARN_FILE=$(mktemp)
    OWNS_WARN_FILE=1
    export WARN_FILE
  fi
}
warn() {
  echo -e "${CYLW}  ! $1${C0}"
  # also collect for the parent process when running as an install step
  [[ -n "${WARN_FILE:-}" ]] && echo "$1" >> "$WARN_FILE" 2>/dev/null || true
}

lower() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]'; }

require_root() {
  [[ "$DEMO" == "1" ]] && return 0
  [[ $EUID -ne 0 ]] && die "$(t err_root)"
  return 0
}

require_ubuntu() {
  [[ "$DEMO" == "1" ]] && return 0
  command -v apt-get >/dev/null || die "$(t err_ubuntu)"
  return 0
}

init_dirs() {
  mkdir -p "$CONF_DIR" 2>/dev/null || true
  mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
  touch "$LOG_FILE" 2>/dev/null || LOG_FILE="${TMPDIR:-/tmp}/vps-setup.log"
}

load_lang() {
  if [[ -n "${VPS_LANG:-}" ]]; then
    UI_LANG="$(lower "$VPS_LANG")"
  elif [[ -f "$LANG_FILE" ]]; then
    UI_LANG="$(head -c 8 "$LANG_FILE" | tr -cd 'a-z')"
  fi
  [[ "$UI_LANG" == "uz" || "$UI_LANG" == "en" ]] || UI_LANG="en"
}

save_lang() {
  mkdir -p "$CONF_DIR" 2>/dev/null || true
  printf '%s\n' "$1" > "$LANG_FILE" 2>/dev/null || true
}

# ---------------------------------------------------------------------
# apt wrappers (identical protections to the original script)
# ---------------------------------------------------------------------
export DEBIAN_FRONTEND=noninteractive
export NEEDRESTART_MODE=a
APT="apt-get -y -o Dpkg::Options::=--force-confdef -o Dpkg::Options::=--force-confold"

wait_for_apt() {
  local n=0
  while ! flock -n /var/lib/dpkg/lock-frontend true 2>/dev/null; do
    n=$((n+1))
    [[ $n -eq 1 ]] && echo "  apt is busy (cloud-init?), waiting..."
    [[ $n -gt 60 ]] && { warn "$(t w_apt_lock)"; break; }
    sleep 5
  done
  return 0
}

# Write a config file; if an existing one differs, back it up first.
write_config() {
  local dest="$1" tmp
  tmp=$(mktemp)
  cat > "$tmp"
  if [[ -f "$dest" ]] && ! cmp -s "$tmp" "$dest"; then
    cp "$dest" "${dest}.bak.$(date +%Y%m%d-%H%M%S)"
    warn "$(basename "$dest"): $(t w_cfg_backup) ${dest}.bak.*"
  fi
  mv "$tmp" "$dest"
}

# ---------------------------------------------------------------------
# IP detection (lazy ‚ÄĒ only needed for installs / creds)
# ---------------------------------------------------------------------
LOCAL_IP="" SERVER_IP=""
detect_ips() {
  [[ -n "$SERVER_IP" ]] && return 0
  if [[ "$DEMO" == "1" ]]; then
    LOCAL_IP="10.0.0.5"; SERVER_IP="203.0.113.10"; return 0
  fi
  LOCAL_IP=$(ip route get 1.1.1.1 2>/dev/null | grep -oP 'src \K\S+' | head -1 || true)
  local public_ip
  public_ip=$(curl -4 -s --max-time 5 ifconfig.me 2>/dev/null || true)
  SERVER_IP=${public_ip:-$LOCAL_IP}
  [[ -z "$SERVER_IP" ]] && SERVER_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
  [[ -z "$LOCAL_IP" ]] && LOCAL_IP="$SERVER_IP"
  return 0
}

os_pretty() {
