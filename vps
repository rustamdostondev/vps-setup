cmd_update() {
  require_root
  # placeholder literal is split so a blanket `sed s/PLACEHOLDER/youruser/`
  # over the repo rewrites REPO_SLUG but leaves this guard intact
  if [[ "$REPO_SLUG" == *"YOUR-GITHUB-""USERNAME"* ]]; then
    die "$(t upd_placeholder)"
  fi
  echo "$(t upd_checking)"
  local tmp newver sha url api
  tmp=$(mktemp)
  # GitHub's CDN caches the mutable 'main' ref for up to ~5 min, so a plain
  # raw/main fetch can serve a stale copy right after a release. Resolve the
  # latest commit SHA and fetch a COMMIT-PINNED raw URL instead ‚ÄĒ that content
  # is immutable and never stale. Fall back to raw/main (with no-cache hints)
  # if the API is unreachable or rate-limited.
  api=$(curl -fsSL -H 'Accept: application/vnd.github+json' \
        "https://api.github.com/repos/${REPO_SLUG}/commits/main" 2>/dev/null || true)
  sha=$(printf '%s' "$api" | grep -oE '[0-9a-f]{40}' | head -1 || true)
  if [[ -n "$sha" ]]; then
    url="https://raw.githubusercontent.com/${REPO_SLUG}/${sha}/vps"
  else
    url="$RAW_BASE/vps"
  fi
  # a corrupted download must never replace a working CLI: marker check,
  # syntax check and a non-empty version are all required
  if ! curl -fsSL -H 'Cache-Control: no-cache' -H 'Pragma: no-cache' "$url" -o "$tmp" \
     || ! grep -q "^# VPS-SETUP-CLI" "$tmp" \
     || ! bash -n "$tmp" 2>/dev/null; then
    rm -f "$tmp"
    die "$(t upd_fail)"
  fi
  newver=$(grep -m1 '^VERSION=' "$tmp" | cut -d'"' -f2 || true)
  if [[ -z "$newver" ]]; then
    rm -f "$tmp"
    die "$(t upd_fail)"
  fi
  if [[ "$newver" == "$VERSION" ]]; then
    rm -f "$tmp"
    echo "${CGRN}${G_OK} $(t upd_latest) (v${VERSION})${C0}"
    return 0
  fi
  install -m 0755 "$tmp" "$SELF"
  rm -f "$tmp"
  echo "${CBGRN}${G_OK} $(t upd_done) v${newver}${C0}"
}

# `vps help <service>` ‚ÄĒ focused help for one service:
# description, dependencies, install command, and full paths/management.
cmd_help_service() {
  local s="$1" st deps
  init_dirs
  compute_statuses
  detect_ips
  _info_load_env
  st="$(get_status "$s")"
  printf '\n  %s%s%s  %s\n\n' "$CB" "$(t "svc_$s")" "$C0" "$(status_glyph "$st")"
  _ir "$(t h_what)"  "$(t "desc_$s")"
  deps="$(svc_deps "$s")"; [[ -z "$deps" ]] && deps="$(t h_none_dep)"
  _ir "$(t h_needs)" "$deps"
  _ir "$(t h_install_cmd)" "sudo vps install $s   ${CD}($(t h_dep_note))${C0}"
  # paths & management (same block as `vps info <service>`)
  printf '\n  %s%s%s\n' "$CB" "$(t info_title)" "$C0"
  [[ "$st" == "off" ]] && printf '     %s%s%s\n' "$CD" "$(t info_off)" "$C0"
  "info_$s"
  echo ""
}

cmd_help() {
