# =====================================================================
# main
# =====================================================================
main() {
  load_lang
  init_warn_file

  # Internal dispatch: `vps __step <svc>` runs ONE install function in this
  # fresh process, where `set -e` is fully honored (see run_service). Not a
  # public command.
  if [[ "${1:-}" == "__step" ]]; then
    local svc="${2:-}"
    is_service "$svc" || exit 64
    STEP="$svc"
    "install_$svc"
    exit 0
  fi

  local cmd="${1:-menu}"
  case "$cmd" in
    menu|"")            init_dirs; STEP="menu";    cmd_menu ;;
    # `|| exit 1`: a failed service is an already-reported outcome ‚ÄĒ it must
    # exit 1 without re-triggering the unexpected-error (ERR) trap
    install)            shift;     STEP="install"; cmd_install "$@" || exit 1 ;;
    status)             init_dirs; STEP="status";  cmd_status ;;
    info)               shift; init_dirs; STEP="info"; cmd_info "$@" ;;
    creds|credentials)  STEP="creds";  cmd_creds ;;
    logs)               STEP="logs";   cmd_logs ;;
    lang)               shift;         cmd_lang "${1:-}" ;;
    update|self-update) STEP="update"; cmd_update ;;
    version|-v|--version) echo "vps-setup v${VERSION}" ;;
    help|-h|--help)     shift; STEP="help"; cmd_help "$@" ;;
    *)
      echo "${CRED}unknown command: $cmd${C0}" >&2
      cmd_help
      exit 1
      ;;
  esac
}

# Library mode (tests): `VPS_SETUP_LIB=1 source ./vps` loads functions only
if [[ "${VPS_SETUP_LIB:-}" == "1" ]]; then
  return 0 2>/dev/null || exit 0
fi

main "$@"
