# vps info            ‚Üí all installed services
# vps info <service>  ‚Üí one service (installed or not)
cmd_info() {
  require_root
  compute_statuses
  detect_ips
  _info_load_env
  echo ""
  echo "  ${CB}$(t info_title)${C0}  ${CD}$(os_pretty)${C0}"

  if [[ $# -gt 0 ]]; then
    local s
    for s in "$@"; do
      s="$(lower "$s")"
      is_service "$s" || die "$(t err_unknown_svc) $s  (services: ${SERVICES[*]})"
      print_info "$s"
    done
    echo ""
    return 0
  fi

  # no arg ‚Üí every installed (or partial) service
  local s any=0
  for s in "${SERVICES[@]}"; do
    if [[ "$(get_status "$s")" != "off" ]]; then
      print_info "$s"; any=1
    fi
  done
  echo ""
  [[ $any -eq 0 ]] && echo "  ${CYLW}$(t info_none)${C0}" && echo ""
  return 0
}

