# =====================================================================
# Runner ‚ÄĒ executes a queue of services with a spinner + live log tail
# =====================================================================
CHILD_PID=""

spin_wait() {  # $1 = pid, $2 = title
  local pid="$1" title="$2" i=0 line frame nf=${#SPIN_FRAMES} cols max
  [[ "$SPIN_FRAMES" == ‚†č* ]] && nf=10
  tput civis 2>/dev/null || true
  while kill -0 "$pid" 2>/dev/null; do
    if [[ "$SPIN_FRAMES" == ‚†č* ]]; then
      frame="${SPIN_FRAMES:$((i % 10)):1}"
    else
      frame="${SPIN_FRAMES:$((i % nf)):1}"
    fi
    # never exceed the terminal width ‚ÄĒ a wrapped line breaks \r redraw and
    # floods the screen with stale frames (recomputed to survive resize)
    cols=$(tput cols 2>/dev/null || echo 80)
    [[ ${#title} -gt $((cols - 8)) ]] && title="${title:0:$((cols - 8))}"
    max=$((cols - ${#title} - 8))
    line=""
    if [[ $max -ge 10 ]]; then
      line=$(tail -n 1 "$LOG_FILE" 2>/dev/null | LC_ALL=C tr -dc '[:print:]' | cut -c1-"$max" || true)
    fi
    printf '\r\033[K  %s%s%s %s %s%s%s' "$CCYN" "$frame" "$C0" "$title" "$CD" "$line" "$C0"
    i=$((i+1))
    sleep 0.12
  done
  printf '\r\033[K'
  tput cnorm 2>/dev/null || true
}

# Build RUN_QUEUE from requested service names: resolve dependencies,
# order canonically, skip already-installed dependencies.
RUN_QUEUE=() QUEUE_NOTES=()
build_queue() {
  local requested=" $* " expanded="" s d
  for s in "$@"; do
    for d in $(svc_deps "$s"); do expanded+=" $d"; done
    expanded+=" $s"
  done
  RUN_QUEUE=() QUEUE_NOTES=()
  for s in "${SERVICES[@]}"; do
    [[ " $expanded " == *" $s "* ]] || continue
    if [[ "$requested" == *" $s "* ]]; then
      RUN_QUEUE+=("$s"); QUEUE_NOTES+=("")
    elif [[ "$(get_status "$s")" == "ok" ]]; then
      QUEUE_NOTES+=("skip:$s")      # dependency already satisfied
    else
      RUN_QUEUE+=("$s"); QUEUE_NOTES+=("dep:$s")
    fi
  done
}

print_plan() {
  local s note
  echo ""
  echo "${CB}$(t plan_title)${C0}"
  for s in "${RUN_QUEUE[@]}"; do
    note=""
    for n in "${QUEUE_NOTES[@]}"; do
      [[ "$n" == "dep:$s" ]] && note=" ${CD}$(t plan_dep)${C0}"
    done
    echo "  ${CCYN}${G_CUR}${C0} $(t "svc_$s")$note"
  done
  for n in "${QUEUE_NOTES[@]}"; do
    if [[ "$n" == skip:* ]]; then
      echo "  ${CGRY}${G_OK} $(t "svc_${n#skip:}") $(t plan_skip)${C0}"
    fi
  done
  echo ""
}

run_service() {  # $1 = svc, $2 = index, $3 = total ‚Üí returns install rc
  local svc="$1" idx="$2" total="$3" rc=0 started elapsed
  printf '\n%s==>%s %s[%s/%s]%s %s\n' "$CBGRN" "$C0" "$CB" "$idx" "$total" "$C0" "$(t "svc_$svc")"
  started=$(date +%s)
  : > "$WARN_FILE"
  {
    echo ""
    echo "===== [$(date)] install: $svc ====="
  } >> "$LOG_FILE"

  # Each step runs as a FRESH bash process (vps __step <svc>): `set -e`
  # inside a subshell spawned from an if/|| context is silently ignored by
  # bash, which would mask mid-step failures and report broken installs as
  # successful. A fresh process gets full errexit semantics.
  # setsid puts it in its own process group so Ctrl-C can kill apt/dpkg
  # children too (they would otherwise keep holding the dpkg lock).
  if [[ $IS_TTY -eq 1 ]]; then
    if command -v setsid >/dev/null 2>&1; then
      setsid "$BASH" "$SELF" __step "$svc" >> "$LOG_FILE" 2>&1 < /dev/null &
    else
      "$BASH" "$SELF" __step "$svc" >> "$LOG_FILE" 2>&1 < /dev/null &
    fi
    CHILD_PID=$!
    spin_wait "$CHILD_PID" "$(t "svc_$svc") ‚ÄĒ $(t installing)"
    if wait "$CHILD_PID"; then rc=0; else rc=$?; fi
    CHILD_PID=""
  else
    if "$BASH" "$SELF" __step "$svc" >> "$LOG_FILE" 2>&1 < /dev/null; then rc=0; else rc=$?; fi
  fi

  elapsed=$(( $(date +%s) - started ))
  if [[ $rc -eq 0 ]]; then
    printf '  %s%s %s%s %s%s %ss%s\n' "$CGRN" "$G_OK" "$(t "svc_$svc")" "$C0" "$CD" "$(t done_in)" "$elapsed" "$C0"
    if [[ -s "$WARN_FILE" ]]; then
      while IFS= read -r wline; do
        printf '  %s! %s%s\n' "$CYLW" "$wline" "$C0"
      done < "$WARN_FILE"
    fi
  else
    printf '  %s%s %s ‚ÄĒ %s%s\n' "$CRED" "$G_ERR" "$(t "svc_$svc")" "$(t failed)" "$C0"
    echo ""
    echo "${CYLW}$(t see_log)${C0}"
    tail -n 15 "$LOG_FILE" 2>/dev/null | sed 's/^/    /'
    echo ""
    echo "${CYLW}$(t rerun) ${C0}"
    echo "${CD}$(t full_log) $LOG_FILE${C0}"
  fi
  return $rc
}

run_queue() {  # runs RUN_QUEUE; returns 0 if all succeeded
  local total=${#RUN_QUEUE[@]} idx=0 svc failed_list="" d dep_failed
  for svc in "${RUN_QUEUE[@]}"; do
    idx=$((idx+1))
    # a service whose dependency failed is skipped, but independent
    # services later in the queue (nginx, firewall, sshkey...) still run
    dep_failed=""
    for d in $(svc_deps "$svc"); do
      [[ " $failed_list " == *" $d "* ]] && dep_failed="$d"
    done
    if [[ -n "$dep_failed" ]]; then
      printf '\n%s==>%s %s[%s/%s]%s %s\n' "$CBGRN" "$C0" "$CB" "$idx" "$total" "$C0" "$(t "svc_$svc")"
      printf '  %s%s %s ‚ÄĒ %s%s\n' "$CYLW" "$G_OFF" "$(t "svc_$svc")" "$(t q_dep_skip)" "$C0"
      failed_list+=" $svc"
      continue
    fi
    if ! run_service "$svc" "$idx" "$total"; then
      failed_list+=" $svc"
    fi
  done

  # regenerate credentials whenever infra/keys may have changed
  case " ${RUN_QUEUE[*]} " in
    *" postgres "*|*" valkey "*|*" minio "*|*" sshkey "*)
      gen_creds
      if [[ -f "$CREDS_FILE" ]]; then
        echo ""
        echo "${CBCYN}$(t creds_saved)${C0} ${CB}${CREDS_FILE}${C0}  ${CD}(vps creds)${C0}"
      fi
      ;;
  esac

  # pointer to the paths/management reference for what was just installed
  echo ""
  echo "${CBCYN}$(t info_hint)${C0} ${CD}vps info${C0}"

  if [[ -z "$failed_list" ]]; then
    echo ""
    echo "${CBGRN}${G_OK} $(t all_done)${C0}"
    return 0
  fi
  echo ""
  echo "${CRED}$(t q_some_failed)${C0}"
  return 1
}

