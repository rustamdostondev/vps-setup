menu_install_flow() {
  local requested=() i answer
  for i in "${!SERVICES[@]}"; do
    [[ "${SEL[$i]}" == "1" ]] && requested+=("${SERVICES[$i]}")
  done
  # nothing marked ‚Üí install the highlighted service
  [[ ${#requested[@]} -eq 0 ]] && requested=("${SERVICES[$CUR]}")

  leave_alt
  validate_supplied_passwords
  build_queue "${requested[@]}"

  if [[ ${#RUN_QUEUE[@]} -eq 0 ]]; then
    echo ""
    echo "${CGRN}${G_OK} $(t nothing)${C0}"
  else
    print_plan
    printf '%s' "${CB}$(t confirm)${C0}"
    IFS= read -r answer || answer=""
    case "$(lower "$answer")" in
      y|yes|ha)
        run_queue || true
        compute_statuses
        ;;
      *) echo "$(t cancelled)" ;;
    esac
  fi

  echo ""
  printf '%s' "${CD}$(t press_key)${C0}"
  IFS= read -rsn1 || true
  enter_alt
  # reset selection after an install round
  for i in "${!SERVICES[@]}"; do SEL[$i]=0; done
}

