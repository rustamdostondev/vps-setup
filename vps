# --- real status probes (Ubuntu server) ---
status_system() {
  local miss=0 p
  for p in git curl jq htop tmux; do command -v "$p" >/dev/null 2>&1 || miss=$((miss+1)); done
  dpkg -s fail2ban >/dev/null 2>&1 || miss=$((miss+1))
  if [[ $miss -eq 0 ]]; then echo ok; elif [[ $miss -le 4 ]]; then echo part; else echo off; fi
}
status_swap() { swapon --show 2>/dev/null | grep -q . && echo ok || echo off; }
status_nodejs() {
  command -v node >/dev/null 2>&1 || { echo off; return; }
  [[ "$(node -v 2>/dev/null | cut -d. -f1)" == "v24" ]] && echo ok || echo part
}
status_docker() {
  command -v docker >/dev/null 2>&1 || { echo off; return; }
  docker info >/dev/null 2>&1 && echo ok || echo part
}
_container_status() {  # $1 = container name
  command -v docker >/dev/null 2>&1 || { echo off; return; }
  if docker ps --format '{{.Names}}' 2>/dev/null | grep -qx "$1"; then echo ok
  elif docker ps -a --format '{{.Names}}' 2>/dev/null | grep -qx "$1"; then echo part
  else echo off; fi
}
status_postgres() { _container_status postgres; }
status_valkey()   { _container_status valkey; }
status_minio()    { _container_status minio; }
status_backup()   { [[ -x /etc/cron.daily/pg-backup ]] && echo ok || echo off; }
status_nginx() {
  command -v nginx >/dev/null 2>&1 || { echo off; return; }
  if [[ -f /etc/nginx/sites-available/app ]] && systemctl is-active nginx >/dev/null 2>&1; then echo ok
  else echo part; fi
}
status_firewall() {
  command -v ufw >/dev/null 2>&1 || { echo off; return; }
  ufw status 2>/dev/null | head -1 | grep -qi active && echo ok || echo part
}
status_sshkey() { [[ -f "$CICD_KEY" ]] && echo ok || echo off; }

# --- demo status (mixed preset + whatever was "installed" this session) ---
demo_status() {
  if [[ -f "$DEMO_STATE" ]] && grep -qx "$1" "$DEMO_STATE" 2>/dev/null; then echo ok; return; fi
  case "$1" in
    system|docker) echo ok ;;
    nodejs|firewall) echo part ;;
    *) echo off ;;
  esac
}

svc_status() {
  if [[ "$DEMO" == "1" ]]; then demo_status "$1"; else "status_$1"; fi
}

compute_statuses() {
  local s
  N_OK=0
  for s in "${SERVICES[@]}"; do
    printf -v "ST_$s" '%s' "$(svc_status "$s")"
    local v="ST_$s"
    [[ "${!v}" == "ok" ]] && N_OK=$((N_OK+1))
  done
  return 0
}
get_status() { local v="ST_$1"; printf '%s' "${!v-off}"; }

status_glyph() {
  case "$1" in
    ok)   printf '%s' "${CGRN}${G_OK} $(t st_ok)${C0}" ;;
    part) printf '%s' "${CYLW}${G_PART} $(t st_part)${C0}" ;;
    *)    printf '%s' "${CGRY}${G_OFF} $(t st_off)${C0}" ;;
  esac
}

# =====================================================================
# .env / compose helpers (shared by postgres, valkey, minio)
# =====================================================================
validate_password() {
  local name="$1" val="$2"
  local re='^[A-Za-z0-9._!@#%^*+=:,-]+$'
  if [[ ! "$val" =~ $re ]]; then
    echo "ERROR ${name}: forbidden character ‚ÄĒ would break .env/compose." >&2
    echo "Allowed: letters, digits and - _ . ! @ # % ^ * + = : , characters." >&2
    exit 1
  fi
  if [[ ${#val} -lt 12 ]]; then
    echo "ERROR ${name} too short ‚ÄĒ use at least 12 characters for production." >&2
    exit 1
  fi
}

# Validate any user-supplied passwords up front (in the parent process,
# before anything is installed), so a typo fails fast with a clear message.
validate_supplied_passwords() {
  [[ -n "${POSTGRES_PASSWORD:-}" ]]   && validate_password POSTGRES_PASSWORD "$POSTGRES_PASSWORD"
  [[ -n "${REDIS_PASSWORD:-}" ]]      && validate_password REDIS_PASSWORD "$REDIS_PASSWORD"
  [[ -n "${MINIO_ROOT_PASSWORD:-}" ]] && validate_password MINIO_ROOT_PASSWORD "$MINIO_ROOT_PASSWORD"
  return 0
}

gen_secret() { openssl rand -base64 24 | tr -d '/+=' | cut -c1-24; }

env_has() { [[ -f "$INFRA_DIR/.env" ]] && grep -q "^$1=" "$INFRA_DIR/.env"; }

env_get() { grep "^$1=" "$INFRA_DIR/.env" 2>/dev/null | head -1 | cut -d= -f2- || true; }

# Portable upsert of KEY=VALUE in .env (no `sed -i`, which differs GNU/BSD).
# `|| true`: grep -v returns 1 when every line matched ‚ÄĒ must not abort set -e.
env_set() {
  local k="$1" v="$2" f="$INFRA_DIR/.env" tmp
  touch "$f"
  tmp=$(mktemp)
  grep -v "^${k}=" "$f" > "$tmp" 2>/dev/null || true
  echo "${k}=${v}" >> "$tmp"
  mv "$tmp" "$f"
  chmod 600 "$f"
}

# Create .env with tight permissions BEFORE any secret is written into it
env_init_file() {
  mkdir -p "$INFRA_DIR"
  touch "$INFRA_DIR/.env"
  chmod 600 "$INFRA_DIR/.env"
}

# Seed missing credentials for ONE service group into .env.
# Existing values are ALWAYS kept (idempotent, never overwrites secrets);
# user-supplied env vars are honored only when the key is not yet present.
ensure_env_postgres() {
  env_init_file
  [[ -n "${POSTGRES_PASSWORD:-}" ]] && validate_password POSTGRES_PASSWORD "$POSTGRES_PASSWORD"
  if env_has POSTGRES_PASSWORD; then
    ok "existing Postgres credentials kept (.env)"
    if [[ -n "${POSTGRES_PASSWORD:-}" && "$(env_get POSTGRES_PASSWORD)" != "$POSTGRES_PASSWORD" ]]; then
      warn "POSTGRES_PASSWORD $(t w_env_not_applied) $INFRA_DIR/.env"
    fi
  else
    {
      echo "POSTGRES_USER=${POSTGRES_USER:-appuser}"
      echo "POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-$(gen_secret)}"
      echo "POSTGRES_DB=${POSTGRES_DB:-appdb}"
    } >> "$INFRA_DIR/.env"
    ok "Postgres credentials written to .env"
  fi
}

ensure_env_valkey() {
  env_init_file
  [[ -n "${REDIS_PASSWORD:-}" ]] && validate_password REDIS_PASSWORD "$REDIS_PASSWORD"
  if env_has REDIS_PASSWORD; then
    ok "existing Valkey password kept (.env)"
    if [[ -n "${REDIS_PASSWORD:-}" && "$(env_get REDIS_PASSWORD)" != "$REDIS_PASSWORD" ]]; then
      warn "REDIS_PASSWORD $(t w_env_not_applied) $INFRA_DIR/.env"
    fi
  else
    echo "REDIS_PASSWORD=${REDIS_PASSWORD:-$(gen_secret)}" >> "$INFRA_DIR/.env"
    ok "Valkey password written to .env"
  fi
}

ensure_env_minio() {
  env_init_file
  [[ -n "${MINIO_ROOT_PASSWORD:-}" ]] && validate_password MINIO_ROOT_PASSWORD "$MINIO_ROOT_PASSWORD"
  if env_has MINIO_ROOT_USER; then
    ok "existing MinIO credentials kept (.env)"
    if [[ -n "${MINIO_ROOT_PASSWORD:-}" && "$(env_get MINIO_ROOT_PASSWORD)" != "$MINIO_ROOT_PASSWORD" ]]; then
      warn "MINIO_ROOT_PASSWORD $(t w_env_not_applied) $INFRA_DIR/.env"
    fi
  else
    {
      echo "MINIO_ROOT_USER=${MINIO_ROOT_USER:-minioadmin}"
      echo "MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD:-$(gen_secret)}"
    } >> "$INFRA_DIR/.env"
    ok "MinIO credentials written to .env"
  fi
  # Console exposure toggle ‚ÄĒ only acts when MINIO_CONSOLE_PUBLIC is given,
  # so an ordinary re-install never silently opens or closes the console.
  #   MINIO_CONSOLE_PUBLIC=1 ‚Üí http://SERVER_IP:9001 (plain HTTP, no TLS)
  #   MINIO_CONSOLE_PUBLIC=0 ‚Üí localhost only (SSH tunnel)
  if [[ -n "${MINIO_CONSOLE_PUBLIC:-}" ]]; then
    local bind="127.0.0.1:"
    [[ "$MINIO_CONSOLE_PUBLIC" == "1" ]] && bind=""
    env_set MINIO_CONSOLE_BIND "$bind"
    if [[ -z "$bind" ]]; then warn "$(t w_minio_public)"; fi
  fi
  return 0
}

# true when the console is configured to be publicly bound (empty prefix)
minio_console_public() { env_has MINIO_CONSOLE_BIND && [[ -z "$(env_get MINIO_CONSOLE_BIND)" ]]; }

# The full infra compose file (single source of truth for all 3 services).
# Written idempotently; docker compose only (re)creates the service we start.
ensure_compose() {
  mkdir -p "$INFRA_DIR" "$BACKUP_DIR"
  # The compose file references env vars of ALL three services, so every key
  # must exist for `docker compose up -d <one service>` to work. Missing keys
  # are seeded with REAL secrets (env override or generated) ‚ÄĒ never with a
  # known placeholder, otherwise a service installed later would go live
  # with a publicly-known password.
  env_init_file
  env_has POSTGRES_USER        || echo "POSTGRES_USER=${POSTGRES_USER:-appuser}" >> "$INFRA_DIR/.env"
  env_has POSTGRES_PASSWORD    || echo "POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-$(gen_secret)}" >> "$INFRA_DIR/.env"
  env_has POSTGRES_DB          || echo "POSTGRES_DB=${POSTGRES_DB:-appdb}" >> "$INFRA_DIR/.env"
  env_has REDIS_PASSWORD       || echo "REDIS_PASSWORD=${REDIS_PASSWORD:-$(gen_secret)}" >> "$INFRA_DIR/.env"
  env_has MINIO_ROOT_USER      || echo "MINIO_ROOT_USER=${MINIO_ROOT_USER:-minioadmin}" >> "$INFRA_DIR/.env"
  env_has MINIO_ROOT_PASSWORD  || echo "MINIO_ROOT_PASSWORD=${MINIO_ROOT_PASSWORD:-$(gen_secret)}" >> "$INFRA_DIR/.env"
  # Console bind prefix: "127.0.0.1:" = localhost only (default, secure);
  # ""(empty) = exposed on all interfaces (http://SERVER_IP:9001).
  # Toggled by ensure_env_minio via MINIO_CONSOLE_PUBLIC.
  env_has MINIO_CONSOLE_BIND   || echo "MINIO_CONSOLE_BIND=127.0.0.1:" >> "$INFRA_DIR/.env"

  write_config "$INFRA_DIR/docker-compose.yml" <<'COMPOSE'
services:

  postgres:
    image: postgres:18
    container_name: postgres
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${POSTGRES_USER}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_DB: ${POSTGRES_DB}
    ports:
      - "5432:5432"        # external tools (DBeaver, backend) connect here
    volumes:
      - pg_data:/var/lib/postgresql/data
    command: >
      postgres
      -c max_connections=100
      -c shared_buffers=256MB
      -c work_mem=8MB
      -c effective_cache_size=768MB
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $$POSTGRES_USER -d $$POSTGRES_DB"]
      interval: 10s
      timeout: 5s
      retries: 10

  valkey:
    image: valkey/valkey:8
    container_name: valkey
    restart: unless-stopped
    environment:
      REDIS_PASSWORD: ${REDIS_PASSWORD}
    ports:
      - "6379:6379"        # external access
    volumes:
      - valkey_data:/data
    command: >
      valkey-server
      --requirepass ${REDIS_PASSWORD}
      --appendonly yes
      --maxmemory 256mb
      --maxmemory-policy allkeys-lru
    healthcheck:
      test: ["CMD-SHELL", "valkey-cli --no-auth-warning -a \"$$REDIS_PASSWORD\" ping | grep -q PONG"]
      interval: 10s
      timeout: 5s
      retries: 10

  minio:
    image: minio/minio:latest
    container_name: minio
    restart: unless-stopped
    environment:
      MINIO_ROOT_USER: ${MINIO_ROOT_USER}
      MINIO_ROOT_PASSWORD: ${MINIO_ROOT_PASSWORD}
    ports:
      - "127.0.0.1:9000:9000"   # S3 API  ‚ÄĒ localhost only (nginx serves it publicly)
      - "${MINIO_CONSOLE_BIND-127.0.0.1:}9001:9001"   # Console ‚ÄĒ localhost by default; MINIO_CONSOLE_BIND="" exposes it
    volumes:
      - minio_data:/data
    command: server /data --console-address ":9001"
    # Note: the MinIO image is distroless (no curl/sh) so no container
    # healthcheck ‚ÄĒ readiness is checked from the host instead.

volumes:
  pg_data:
  valkey_data:
  minio_data:
COMPOSE
}

# Warn if a port is held by a non-docker process (e.g. native postgres)
check_port_conflict() {
  local p="$1" pinfo
  pinfo=$(ss -ltnp "sport = :$p" 2>/dev/null | tail -n +2 || true)
  if [[ -n "$pinfo" ]] && ! grep -q docker <<<"$pinfo"; then
    warn "port $p: $(t w_port_busy) $INFRA_DIR/docker-compose.yml"
  fi
}

# Open a firewall port if UFW is already active (so installing a DB after
# the firewall still exposes it, matching the all-at-once behaviour)
ufw_allow_if_active() {
  local port="$1" comment="$2"
  command -v ufw >/dev/null 2>&1 || return 0
  if ufw status 2>/dev/null | head -1 | grep -qi active; then
    ufw allow "${port}/tcp" comment "$comment" >/dev/null 2>&1 || true
    ok "firewall: opened ${port}/tcp"
  fi
  return 0
}

compose_up() {  # $1 = service name
  cd "$INFRA_DIR"
  if docker compose up -d "$1"; then
    ok "docker compose: $1 started"
  else
    warn "$1: $(t w_compose_fail) docker compose -f $INFRA_DIR/docker-compose.yml logs $1"
    return 1
  fi
}

wait_ready() {  # $1 = label, $2... = check command
  local label="$1"; shift
  local i
  echo "  waiting for $label (up to 60s)..."
  for i in $(seq 1 30); do
    if "$@" >/dev/null 2>&1; then ok "$label is ready"; return 0; fi
    sleep 2
  done
  warn "$label $(t w_not_ready) docker logs $label"
  return 0
}

# =====================================================================
# INSTALL FUNCTIONS ‚ÄĒ faithful ports of the original vps-setup.sh steps.
# Each runs with stdout+stderr redirected to $LOG_FILE.
# =====================================================================
demo_install() {
  local s
  for s in "downloading packages" "configuring" "starting service" "verifying"; do
    echo "==> $s..."; sleep 0.4
  done
  mkdir -p "$CONF_DIR"; echo "$1" >> "$DEMO_STATE"
  echo "demo: $1 marked as installed"
}

install_system() {
  [[ "$DEMO" == "1" ]] && { demo_install system; return; }
  echo "==> apt update + upgrade"
  wait_for_apt; $APT update; $APT upgrade
  echo "==> installing base tools"
  wait_for_apt
  $APT install \
    git curl wget unzip jq htop tmux \
    ca-certificates gnupg openssl \
    ufw fail2ban unattended-upgrades
  ok "base tools installed"
}

install_swap() {
  [[ "$DEMO" == "1" ]] && { demo_install swap; return; }
  if swapon --show | grep -q .; then
    ok "swap already active ‚ÄĒ skipped"
    return 0
  fi
  echo "==> creating 2GB swapfile"
  fallocate -l 2G /swapfile 2>/dev/null || dd if=/dev/zero of=/swapfile bs=1M count=2048 status=none
  chmod 600 /swapfile
  mkswap /swapfile >/dev/null
  swapon /swapfile
  grep -q '^/swapfile' /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
  echo 'vm.swappiness=10' > /etc/sysctl.d/99-swap.conf
  sysctl -p /etc/sysctl.d/99-swap.conf >/dev/null
  ok "swap active"
}

install_nodejs() {
  [[ "$DEMO" == "1" ]] && { demo_install nodejs; return; }
  if command -v node >/dev/null && [[ "$(node -v | cut -d. -f1)" == "v24" ]]; then
    ok "Node.js 24 already installed: $(node -v)"
    return 0
  fi
  echo "==> installing Node.js 24 LTS (NodeSource)"
  curl -fsSL https://deb.nodesource.com/setup_24.x | bash - >/dev/null
  wait_for_apt
  $APT install nodejs
  ok "Node.js $(node -v) installed"
}

install_docker() {
  [[ "$DEMO" == "1" ]] && { demo_install docker; return; }
  if command -v docker >/dev/null; then
    ok "Docker already installed: $(docker --version | awk '{print $3}' | tr -d ',')"
  else
    echo "==> installing Docker CE"
    install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
    chmod a+r /etc/apt/keyrings/docker.asc
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] \
https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
      > /etc/apt/sources.list.d/docker.list
    wait_for_apt
    $APT update
    $APT install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  fi
  systemctl enable --now docker >/dev/null 2>&1

  # Log rotation ‚ÄĒ only when daemon.json does NOT exist yet.
  # (If it exists we leave it alone and do NOT restart docker, so running
  #  containers on an existing server are never interrupted.)
  if [[ ! -f /etc/docker/daemon.json ]]; then
    cat > /etc/docker/daemon.json <<'EOF'
{
  "log-driver": "json-file",
  "log-opts": { "max-size": "10m", "max-file": "3" }
}
EOF
    systemctl restart docker
    ok "log rotation configured"
  else
    ok "daemon.json exists ‚ÄĒ left untouched (keeps running containers alive)"
  fi

  # Swarm (single-node) ‚ÄĒ non-fatal if it cannot init
  if docker info --format '{{.Swarm.LocalNodeState}}' 2>/dev/null | grep -q active; then
    ok "Swarm already active"
  else
    detect_ips
    if docker swarm init --advertise-addr "$LOCAL_IP" >/dev/null 2>&1 \
