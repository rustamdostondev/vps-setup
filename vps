install_firewall() {
  [[ "$DEMO" == "1" ]] && { demo_install firewall; return; }
  echo "==> configuring UFW firewall"

  # --- SSH LOCKOUT PROTECTION ---
  # Detect the SSH port (22 or custom) from config AND the live listener.
  # `|| true` guards: a no-match grep must not abort the step under set -e.
  local ssh_port listen_port
  ssh_port=$(grep -iE "^\s*Port\s+[0-9]+" /etc/ssh/sshd_config 2>/dev/null | awk '{print $2}' | head -1 || true)
  ssh_port=${ssh_port:-22}
  listen_port=$(ss -tlnp 2>/dev/null | grep -m1 '"sshd"' | awk '{print $4}' | rev | cut -d: -f1 | rev || true)
  [[ -n "${listen_port:-}" ]] && ssh_port="$listen_port"
  ok "SSH port detected: ${ssh_port}"

  ufw default deny incoming >/dev/null
  ufw default allow outgoing >/dev/null
  ufw allow "${ssh_port}/tcp" comment 'SSH' >/dev/null
  ufw allow 80/tcp  >/dev/null
  ufw allow 443/tcp >/dev/null

  # Only open DB ports for services that actually exist on this server
  if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -qx postgres; then
    ufw allow 5432/tcp comment 'PostgreSQL' >/dev/null
    ok "5432/tcp opened (postgres present)"
  fi
  if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -qx valkey; then
    ufw allow 6379/tcp comment 'Valkey' >/dev/null
    ok "6379/tcp opened (valkey present)"
  fi
  # MinIO console only when it is configured public (MINIO_CONSOLE_PUBLIC=1)
  if docker ps -a --format '{{.Names}}' 2>/dev/null | grep -qx minio && minio_console_public; then
    ufw allow 9001/tcp comment 'MinIO console' >/dev/null
    ok "9001/tcp opened (MinIO console public)"
  fi
  # SAFER variant (if you have a static IP):
  #   ufw delete allow 5432/tcp && ufw allow from YOUR_IP to any port 5432

  # PROTECTION: the firewall is NOT enabled until the SSH rule is confirmed
  if ufw show added 2>/dev/null | grep -q "${ssh_port}/tcp" \
     || ufw status 2>/dev/null | grep -q "${ssh_port}/tcp"; then
    ufw --force enable >/dev/null
    ok "firewall active (SSH:${ssh_port}, 80, 443 open)"
  else
    warn "SSH ${ssh_port}/tcp: $(t w_fw_off)"
  fi

  systemctl enable --now fail2ban >/dev/null 2>&1
  dpkg-reconfigure -f noninteractive unattended-upgrades >/dev/null 2>&1
  ok "fail2ban + unattended-upgrades active"
}

